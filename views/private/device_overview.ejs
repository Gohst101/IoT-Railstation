<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/device_overview.css">
    <link rel="stylesheet" href="/css/notification.css">
    <title>Device Overview</title>
</head>
<body>

    <%- include('../partials/overlay') %>
    <%- include('../partials/blur') %>

    <% const totalDevices = devices ? devices.length : 0; %>
    <% const onlineDevices = devices ? devices.filter(device => device.online).length : 0; %>
    <% const offlineDevices = Math.max(totalDevices - onlineDevices, 0); %>

    <main>
        <div class="action-bar-container">
            <div class="search-bar">
                <img src="/img/icons/search.svg" alt="Search Icon">
                <input id="search-query" type="text">
            </div>
            <div class="filter">
                <button class="active">Alle (<%= totalDevices %>)</button>
                <button>Online (<%= onlineDevices %>)</button>
                <button>Offline (<%= offlineDevices %>)</button>
            </div>
            <div class="refresh">
                <button>Neu laden</button>
            </div>
        </div>

        <table class="device_container">
            <thead>
                <tr>
                    <th>ALIAS</th>
                    <th>DEVICE ID</th>
                    <th>IP ADRESSE</th>
                    <th>STATUS</th>
                    <th>VERSION</th>
                    <th>LAST SEEN</th>
                </tr>
            </thead>
            <tbody>
                <% if (devices && devices.length > 0) { %>
                    <% devices.forEach(device => { %>
                        <tr>
                            <td><%= device.alias || 'Unknown device' %></td>
                            <td><%= device.device_id || '-' %></td>
                            <td><%= device.ip_address || '-' %></td>
                            <td><%= device.online ? 'Online' : 'Offline' %></td>
                            <td><%= device.version || '-' %></td>
                            <td><%= device.last_seen || '-' %></td>
                        </tr>
                    <% }) %>
                <% } else { %>
                    <tr>
                        <td colspan="6">Keine Geräte gefunden.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </main>

    <script src="/js/notification.js" defer></script>
</body>
</html>